# OPL Studio UI — environment variables
# Copy to .env.local and fill in values before running

# Backend API (proxied via Vite in dev mode)
VITE_DEV_PROXY_TARGET=http://localhost:8080

# Skill Manager UI URL — used by the "Manage Skills" button in the Skills page
# In dev:        http://localhost:8091
# In production: set to the deployed skill-manager URL
VITE_SKILL_MANAGER_URL=http://localhost:8091
